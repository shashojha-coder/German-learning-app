      "sentence_sections": [
        {
          "id": "basic_word_order",
          "title": "Basic Word Order (Subject-Verb-Object)",
          "explanation": "In German, the basic sentence order is Subject + Verb + Object. The verb always takes the second position in main clauses.",
          "exercises": [
            {"prompt": "I drink coffee.", "answer": "Ich trinke Kaffee.", "hint": "trinken → ich trinke", "words": ["Ich", "trinke", "Kaffee"]},
            {"prompt": "She reads a book.", "answer": "Sie liest ein Buch.", "hint": "lesen → sie liest", "words": ["Sie", "liest", "ein", "Buch"]},
            {"prompt": "He plays football.", "answer": "Er spielt Fußball.", "hint": "spielen → er spielt", "words": ["Er", "spielt", "Fußball"]},
            {"prompt": "We eat bread.", "answer": "Wir essen Brot.", "hint": "essen → wir essen", "words": ["Wir", "essen", "Brot"]},
            {"prompt": "You (informal) learn German.", "answer": "Du lernst Deutsch.", "hint": "lernen → du lernst", "words": ["Du", "lernst", "Deutsch"]}
          ]
        },
        {
          "id": "simple_questions",
          "title": "Simple Questions",
          "explanation": "Yes/No questions start with the verb. W-questions (wer, was, wo, wie, wann) start with the question word, followed by verb.",
          "exercises": [
            {"prompt": "Do you speak German?", "answer": "Sprichst du Deutsch?", "hint": "Verb first for yes/no questions", "words": ["Sprichst", "du", "Deutsch"]},
            {"prompt": "Where do you live?", "answer": "Wo wohnst du?", "hint": "W-word + verb + subject", "words": ["Wo", "wohnst", "du"]},
            {"prompt": "What is your name?", "answer": "Wie heißt du?", "hint": "wie = how (used for names)", "words": ["Wie", "heißt", "du"]},
            {"prompt": "Is he a student?", "answer": "Ist er Student?", "hint": "Verb first", "words": ["Ist", "er", "Student"]},
            {"prompt": "When do you come?", "answer": "Wann kommst du?", "hint": "wann = when", "words": ["Wann", "kommst", "du"]}
          ]
        },
        {
          "id": "negation",
          "title": "Negation with nicht / kein",
          "explanation": "'nicht' negates verbs and adjectives. 'kein/keine' negates nouns (replaces ein/eine). Example: Ich habe kein Auto. / Ich laufe nicht.",
          "exercises": [
            {"prompt": "I don't have a car.", "answer": "Ich habe kein Auto.", "hint": "kein replaces ein for negation", "words": ["Ich", "habe", "kein", "Auto"]},
            {"prompt": "She is not hungry.", "answer": "Sie ist nicht hungrig.", "hint": "nicht before adjectives", "words": ["Sie", "ist", "nicht", "hungrig"]},
            {"prompt": "We don't drink milk.", "answer": "Wir trinken keine Milch.", "hint": "keine for feminine nouns", "words": ["Wir", "trinken", "keine", "Milch"]},
            {"prompt": "He doesn't work today.", "answer": "Er arbeitet heute nicht.", "hint": "nicht at the end", "words": ["Er", "arbeitet", "heute", "nicht"]},
            {"prompt": "I have no money.", "answer": "Ich habe kein Geld.", "hint": "kein for neuter nouns", "words": ["Ich", "habe", "kein", "Geld"]}
          ]
        }
      ]
    },
