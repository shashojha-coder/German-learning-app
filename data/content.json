      "sentence_sections": [
        {
          "id": "past_tense_perfekt",
          "title": "Past Tense (Perfekt)",
          "explanation": "The Perfekt tense uses haben/sein + past participle. Regular verbs: ge- + stem + -t (gemacht). Irregular verbs vary (gegessen, getrunken).",
          "exercises": [
            {"prompt": "I ate an apple.", "answer": "Ich habe einen Apfel gegessen.", "hint": "essen → gegessen (irregular)", "words": ["Ich", "habe", "einen", "Apfel", "gegessen"]},
            {"prompt": "She travelled to Berlin.", "answer": "Sie ist nach Berlin gereist.", "hint": "reisen uses 'sein' (movement)", "words": ["Sie", "ist", "nach", "Berlin", "gereist"]},
            {"prompt": "We bought a car.", "answer": "Wir haben ein Auto gekauft.", "hint": "kaufen → gekauft (regular)", "words": ["Wir", "haben", "ein", "Auto", "gekauft"]},
            {"prompt": "He drank coffee.", "answer": "Er hat Kaffee getrunken.", "hint": "trinken → getrunken", "words": ["Er", "hat", "Kaffee", "getrunken"]},
            {"prompt": "They went home.", "answer": "Sie sind nach Hause gegangen.", "hint": "gehen uses 'sein'", "words": ["Sie", "sind", "nach", "Hause", "gegangen"]}
          ]
        },
        {
          "id": "modal_verbs",
          "title": "Modal Verbs (können, müssen, wollen, sollen, dürfen)",
          "explanation": "Modal verbs modify the main verb. The main verb goes to the END of the sentence in infinitive form. Example: Ich kann Deutsch sprechen.",
          "exercises": [
            {"prompt": "I can speak German.", "answer": "Ich kann Deutsch sprechen.", "hint": "können → ich kann", "words": ["Ich", "kann", "Deutsch", "sprechen"]},
            {"prompt": "You must go to the doctor.", "answer": "Du musst zum Arzt gehen.", "hint": "müssen → du musst", "words": ["Du", "musst", "zum", "Arzt", "gehen"]},
            {"prompt": "She wants to travel.", "answer": "Sie will reisen.", "hint": "wollen → sie will", "words": ["Sie", "will", "reisen"]},
            {"prompt": "We should study more.", "answer": "Wir sollen mehr lernen.", "hint": "sollen → wir sollen", "words": ["Wir", "sollen", "mehr", "lernen"]},
            {"prompt": "May I sit here?", "answer": "Darf ich hier sitzen?", "hint": "dürfen → ich darf", "words": ["Darf", "ich", "hier", "sitzen"]}
          ]
        },
        {
          "id": "connectors_weil_dass",
          "title": "Connectors: weil & dass",
          "explanation": "After 'weil' (because) and 'dass' (that), the conjugated verb goes to the END of the clause. Example: Ich lerne Deutsch, weil ich in Berlin arbeite.",
          "exercises": [
            {"prompt": "I learn German because I work in Berlin.", "answer": "Ich lerne Deutsch, weil ich in Berlin arbeite.", "hint": "Verb at the end after weil", "words": ["Ich", "lerne", "Deutsch", "weil", "ich", "in", "Berlin", "arbeite"]},
            {"prompt": "I think that he is nice.", "answer": "Ich denke, dass er nett ist.", "hint": "Verb at the end after dass", "words": ["Ich", "denke", "dass", "er", "nett", "ist"]},
            {"prompt": "She stays home because she is sick.", "answer": "Sie bleibt zu Hause, weil sie krank ist.", "hint": "krank = sick, verb at end", "words": ["Sie", "bleibt", "zu", "Hause", "weil", "sie", "krank", "ist"]},
            {"prompt": "I know that you speak German.", "answer": "Ich weiß, dass du Deutsch sprichst.", "hint": "wissen = to know", "words": ["Ich", "weiß", "dass", "du", "Deutsch", "sprichst"]},
            {"prompt": "He is happy because he has vacation.", "answer": "Er ist glücklich, weil er Urlaub hat.", "hint": "Urlaub = vacation", "words": ["Er", "ist", "glücklich", "weil", "er", "Urlaub", "hat"]}
          ]
        }
      ]
    },
